let toastTimeout=null;
function showManagerToast(msg){
  let toast=document.getElementById('mgr-toast');
  if(!toast){
    toast=document.createElement('div');
    toast.id='mgr-toast';
    toast.style.cssText='position:fixed;bottom:24px;right:24px;background:#fff;color:#1a1a1c;padding:12px 18px;border-radius:12px;font-size:13px;font-weight:500;box-shadow:0 4px 20px rgba(0,0,0,.3);z-index:999;opacity:0;transform:translateY(8px);transition:all .25s;pointer-events:none;';
    document.body.appendChild(toast);
  }
  toast.textContent=msg;
  toast.style.opacity='1';toast.style.transform='translateY(0)';
  if(toastTimeout)clearTimeout(toastTimeout);
  toastTimeout=setTimeout(()=>{toast.style.opacity='0';toast.style.transform='translateY(8px)';},3000);
}

/* ── LANG ── */
function toggleLang(e){e.stopPropagation();document.getElementById('lang-dd').classList.toggle('open');}
document.addEventListener('click',()=>document.getElementById('lang-dd').classList.remove('open'));

function setLang(l){
  lang=l;const t=I[l];
  document.documentElement.setAttribute('lang',l);
  document.documentElement.setAttribute('dir',t.dir);
  document.getElementById('cur-flag').textContent=t.flag;
  document.getElementById('cur-lname').textContent=t.name;
  document.querySelectorAll('.lang-opt').forEach(o=>o.classList.remove('active'));
  document.querySelectorAll('.lchk').forEach(c=>c.style.display='none');
  document.getElementById('opt-'+l).classList.add('active');
  document.getElementById('lchk-'+l).style.display='inline';
  document.getElementById('lang-dd').classList.remove('open');
  document.querySelectorAll('[data-i18n]').forEach(el=>{const k=el.getAttribute('data-i18n');if(t[k]!==undefined)el.innerHTML=t[k];});
  renderStoreSwitcher();renderStoresGrid();renderSchedule();renderGeoTable();renderTeam();renderActiveStoreLabel();
  renderLeaveMetrics();renderLeaveTable();renderLeaveSummary();
}

