let lang='fr';

/* ══ RENDER FUNCTIONS ══ */
function getActiveStore(){return stores.find(s=>s.id===activeStoreId)||stores[0];}
function getStoreEmps(storeId){return employees.filter(e=>e.stores.includes(storeId));}

function renderStoreSwitcher(){
  const t=I[lang];
  const list=document.getElementById('store-list');
  list.innerHTML=stores.map(s=>`
    <div class="store-btn${s.id===activeStoreId?' active':''}" onclick="switchStore(${s.id})">
      <div class="store-dot" style="background:${s.color};">${s.name.charAt(0)}</div>
      <div class="store-info-col">
        <div class="store-btn-name">${s.name}</div>
        <div class="store-btn-addr">${s.addr.split(',')[0]}</div>
      </div>
      ${s.id===activeStoreId?'<div class="store-active-dot"></div>':''}
    </div>`).join('');
}

function renderStoresGrid(){
  const t=I[lang];
  const grid=document.getElementById('stores-grid');
  grid.innerHTML=stores.map(s=>`
    <div class="store-card${s.id===activeStoreId?' active-store':''}">
      <div class="sc-top">
        <div class="sc-icon" style="background:${s.color};">${s.name.charAt(0)}</div>
        <div>
          <div class="sc-name">${s.name}</div>
          <div class="sc-type">${s.type}</div>
        </div>
        ${s.id===activeStoreId?`<div style="margin-left:auto;font-size:11px;font-weight:500;color:var(--accent2);background:rgba(74,222,128,.1);border:1px solid rgba(74,222,128,.2);padding:2px 8px;border-radius:20px;">${t.activeLabel}</div>`:''}
      </div>
      <div class="sc-body">
        <div class="sc-field">
          <div class="sc-field-label">${t.labelStoreAddr}</div>
          <div class="sc-field-val addr">📍 ${s.addr}</div>
        </div>
        <div class="sc-field">
          <div class="sc-field-label">${t.labelLat} / ${t.labelLng}</div>
          <div class="sc-field-val" style="font-size:12px;color:var(--muted);">${s.lat}, ${s.lng}</div>
        </div>
        <div class="sc-field">
          <div class="sc-field-label">${t.geoRadius}</div>
          <div class="sc-field-val"><span class="radius-badge">⊙ ${s.radius}m</span></div>
        </div>
        <div class="sc-field">
          <div class="sc-field-label">${t.navTeam}</div>
          <div class="sc-field-val" style="font-size:12px;">${getStoreEmps(s.id).length} ${t.metricStaff.toLowerCase()}${getStoreEmps(s.id).filter(e=>e.shared).length>0?` · ${getStoreEmps(s.id).filter(e=>e.shared).length} ${t.sharedLabel.toLowerCase()}`:''}</div>
        </div>
      </div>
      <div class="sc-actions">
        ${s.id!==activeStoreId?`<button class="btn btn-sm" onclick="switchStore(${s.id})">${t.selectStoreBtn}</button>`:`<button class="btn btn-sm" style="opacity:.4;cursor:default;">${t.activeStoreBtn}</button>`}
        <button class="btn btn-sm" onclick="openEditStore(${s.id})">${t.editBtn}</button>
        ${stores.length>1?`<button class="btn btn-sm btn-danger" onclick="deleteStore(${s.id})">${t.deleteBtn}</button>`:''}
      </div>
    </div>`).join('')+`
    <div class="add-store-card" onclick="openAddStore()">
      <div class="add-store-card-icon">＋</div>
      <div class="add-store-card-text" data-i18n="addStore">${t.addStore}</div>
    </div>`;
}

function renderSchedule(){
  const t=I[lang];
  const body=document.getElementById('sched-body');
  const emps=getStoreEmps(activeStoreId);
  body.innerHTML=emps.slice(0,5).map((emp,i)=>{
    let row=`<div class="sched-row">
      <div class="emp-c">
        <div class="eav" style="background:${emp.color}22;color:${emp.color};">${emp.name.split(' ').map(x=>x[0]).join('')}</div>
        <div><div class="ename">${emp.name}</div><div class="erole">${emp.role}</div>${emp.shared?`<span class="shared-tag">⇄ ${t.sharedLabel}</span>`:''}</div>
      </div>`;
    (scheduleData[i]||['off','off','off','off','off','off','off']).forEach((type,d)=>{
      const isTod=d===1;
      row+=`<div class="shift-c${isTod?' today':''}" onclick="openAddShift()">`;
      if(type==='m') row+=`<div class="sb sm">${t.shiftM}<br>6–14</div>`;
      else if(type==='a') row+=`<div class="sb sa">${t.shiftA}<br>14–22</div>`;
      else if(type==='f') row+=`<div class="sb sf">${t.shiftF}<br>8–17</div>`;
      else row+=`<div class="se">+</div>`;
      row+='</div>';
    });
    row+='</div>';return row;
  }).join('');
}

function renderGeoTable(){
  const t=I[lang];
  const store=getActiveStore();
  document.getElementById('geo-radius-display').textContent=store.radius+'m';
  document.getElementById('geo-addr-short').textContent=store.addr.split(',')[0];
  const tbody=document.getElementById('geo-tbody');
  const emps=getStoreEmps(activeStoreId);
  tbody.innerHTML=geoRows.filter(r=>emps.find(e=>e.id===r.empId)).map(r=>{
    const emp=employees.find(e=>e.id===r.empId);if(!emp)return'';
    const bc=r.status==='ok'?'geo-ok':r.status==='out'?'geo-out':'geo-pending';
    const sl=r.status==='ok'?t.geoStatusOk:r.status==='out'?t.geoStatusOut:t.geoStatusPending;
    const distTxt=r.dist?`<span class="dist-pill">📍 ${r.dist}m</span>`:'<span style="color:var(--muted)">—</span>';
    return `<tr>
      <td><div class="emp-cell-row"><div class="eav" style="background:${emp.color}22;color:${emp.color};width:26px;height:26px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:600;flex-shrink:0;">${emp.name.split(' ').map(x=>x[0]).join('')}</div><div><div style="font-size:13px;font-weight:500;">${emp.name}</div><div style="font-size:11px;color:var(--muted);">${emp.role}</div></div></div></td>
      <td style="font-size:12px;color:var(--muted);">${r.shift}</td>
      <td style="font-size:13px;font-weight:500;">${r.time}</td>
      <td>${distTxt}</td>
      <td><span class="geo-badge ${bc}"><span class="gdot"></span>${sl}</span></td>
    </tr>`;
  }).join('');
}

function renderTeam(){
  const t=I[lang];
  const store=getActiveStore();
  document.getElementById('team-title').textContent=`${t.teamLabel} — ${store.name}`;
  const tbody=document.getElementById('team-tbody');
  const emps=getStoreEmps(activeStoreId);
  tbody.innerHTML=emps.map(emp=>{
    const storePills=emp.stores.map(sid=>{
      const s=stores.find(x=>x.id===sid);if(!s)return'';
      return `<span class="store-pill" style="background:${s.color}18;color:${s.color};border:1px solid ${s.color}35;">
        <span style="width:6px;height:6px;border-radius:50%;background:${s.color};display:inline-block;"></span>${s.name.split(' ')[0]}
      </span>`;
    }).join('');
    return `<tr>
      <td><div class="emp-cell-row"><div class="eav" style="background:${emp.color}22;color:${emp.color};width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:600;flex-shrink:0;">${emp.name.split(' ').map(x=>x[0]).join('')}</div><div><div style="font-size:13px;font-weight:500;">${emp.name}</div>${emp.shared?`<span style="font-size:10px;font-weight:600;color:var(--accent3);">⇄ ${t.sharedLabel}</span>`:''}</div></div></td>
      <td style="color:var(--muted);font-size:13px;">${emp.role}</td>
      <td>${storePills}</td>
      <td style="font-size:13px;">${emp.hours}h</td>
      <td><span style="font-size:11px;font-weight:500;padding:2px 8px;border-radius:20px;background:rgba(74,222,128,.1);color:var(--accent2);border:1px solid rgba(74,222,128,.2);">${t.activeLabel}</span></td>
      <td><button class="btn btn-sm" style="font-size:11px;" onclick="openAddEmployee()">${t.editBtn}</button></td>
    </tr>`;
  }).join('');
}

function renderActiveStoreLabel(){
  const s=getActiveStore();
  document.getElementById('active-store-label').textContent=s?`${s.name} · ${s.addr.split(',')[0]}`:'';
  const m=document.getElementById('m-staff');
  if(m)m.textContent=getStoreEmps(activeStoreId).length;
}

/* ══ INTERACTIONS ══ */
function switchStore(id){
  activeStoreId=id;
  stores.forEach(s=>s.active=s.id===id);
  renderStoreSwitcher();
  renderStoresGrid();
  renderSchedule();
  renderGeoTable();
  renderTeam();
  renderActiveStoreLabel();
  renderLeaveMetrics();renderLeaveTable();renderLeaveSummary();
}

function switchPanel(p,el){
  document.querySelectorAll('.panel').forEach(x=>x.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(x=>x.classList.remove('active'));
  document.getElementById('panel-'+p).classList.add('active');
  el.classList.add('active');
  const t=I[lang];
  const map={schedule:t.navSchedule,geo:t.navGeo,team:t.navTeam,leave:t.navLeave,alerts:t.navAlerts,stores:t.navStores};
  document.getElementById('page-title').textContent=map[p]||p;
  if(p==='leave'){renderLeaveMetrics();renderLeaveTable();renderLeaveSummary();}
}

/* ── COLOR PICKER ── */
function buildColorPicker(){
  const cp=document.getElementById('color-picker');
  cp.innerHTML=COLORS.map(c=>`<div class="color-swatch${c===selectedColor?' selected':''}" style="background:${c};" onclick="pickColor('${c}',this)"></div>`).join('');
}
function pickColor(c,el){
  selectedColor=c;
  document.querySelectorAll('.color-swatch').forEach(s=>s.classList.remove('selected'));
  el.classList.add('selected');
}

/* ── STORE MODAL ── */
function openAddStore(){
  editingStoreId=null;
  selectedColor=COLORS[stores.length%COLORS.length];
  document.getElementById('store-modal-title').textContent=I[lang].addStoreTitle;
  document.getElementById('in-store-name').value='';
  document.getElementById('in-store-addr').value='';
  document.getElementById('in-lat').value='';
  document.getElementById('in-lng').value='';
  document.getElementById('in-radius').value='200';
  buildColorPicker();
  document.getElementById('modal-store').classList.add('open');
}
function openEditStore(id){
  editingStoreId=id;
  const s=stores.find(x=>x.id===id);if(!s)return;
  selectedColor=s.color;
  document.getElementById('store-modal-title').textContent=I[lang].editStoreTitle;
  document.getElementById('in-store-name').value=s.name;
  document.getElementById('in-store-addr').value=s.addr;
  document.getElementById('in-lat').value=s.lat;
  document.getElementById('in-lng').value=s.lng;
  document.getElementById('in-radius').value=s.radius;
  buildColorPicker();
  document.getElementById('modal-store').classList.add('open');
}
function saveStore(){
  const name=document.getElementById('in-store-name').value.trim();
  const addr=document.getElementById('in-store-addr').value.trim();
  const lat=parseFloat(document.getElementById('in-lat').value)||48.8566;
  const lng=parseFloat(document.getElementById('in-lng').value)||2.3522;
  const radius=parseInt(document.getElementById('in-radius').value)||200;
  const type=document.getElementById('in-store-type').value;
  if(!name){document.getElementById('in-store-name').focus();return;}
  if(editingStoreId){
    const s=stores.find(x=>x.id===editingStoreId);
    if(s){s.name=name;s.addr=addr;s.lat=lat;s.lng=lng;s.radius=radius;s.color=selectedColor;s.type=type;}
  } else {
    stores.push({id:nextStoreId++,name,type,addr,lat,lng,radius,color:selectedColor,active:false});
  }
  closeModal('store');
  renderStoreSwitcher();renderStoresGrid();renderActiveStoreLabel();
}
function deleteStore(id){
  if(stores.length<=1)return;
  const idx=stores.findIndex(s=>s.id===id);
  if(idx>-1)stores.splice(idx,1);
  if(activeStoreId===id)activeStoreId=stores[0].id;
  employees.forEach(e=>{e.stores=e.stores.filter(s=>s!==id);if(e.stores.length===0)e.stores=[stores[0].id];e.shared=e.stores.length>1;});
  renderStoreSwitcher();renderStoresGrid();renderSchedule();renderGeoTable();renderTeam();renderActiveStoreLabel();
}

/* ── EMPLOYEE MODAL ── */
function openAddEmployee(){
  const boxes=document.getElementById('store-checkboxes');
  boxes.innerHTML=stores.map(s=>`
    <label style="display:flex;align-items:center;gap:10px;padding:8px 10px;border-radius:8px;background:var(--bg3);border:1px solid var(--border);cursor:pointer;">
      <input type="checkbox" value="${s.id}" style="accent-color:${s.color};width:14px;height:14px;" checked>
      <div class="store-dot" style="background:${s.color};width:22px;height:22px;border-radius:6px;font-size:10px;">${s.name.charAt(0)}</div>
      <div><div style="font-size:13px;font-weight:500;">${s.name}</div><div style="font-size:11px;color:var(--muted);">${s.addr.split(',')[0]}</div></div>
    </label>`).join('');
  document.getElementById('in-firstname').value='';
  document.getElementById('in-lastname').value='';
  document.getElementById('in-phone').value='';
  document.getElementById('modal-emp').classList.add('open');
}
function saveEmployee(){
  const first=document.getElementById('in-firstname').value.trim();
  const last=document.getElementById('in-lastname').value.trim();
  if(!first){document.getElementById('in-firstname').focus();return;}
  const role=document.getElementById('in-role').value;
  const checked=[...document.querySelectorAll('#store-checkboxes input:checked')].map(x=>parseInt(x.value));
  const storeIds=checked.length>0?checked:[activeStoreId];
  employees.push({id:nextEmpId++,name:`${first} ${last.charAt(0)}.`,role,color:COLORS[employees.length%COLORS.length],hours:0,stores:storeIds,shared:storeIds.length>1});
  closeModal('emp');
  renderTeam();renderSchedule();renderStoreSwitcher();renderStoresGrid();
}

function openAddShift(){
  const t=I[lang];
  const sel=document.getElementById('sel-emp');
  sel.innerHTML=getStoreEmps(activeStoreId).map(e=>`<option>${e.name} — ${e.role}</option>`).join('');
  const selD=document.getElementById('sel-day');
  selD.innerHTML=t.dayOptions.map(d=>`<option>${d}</option>`).join('');
  document.getElementById('modal-shift').classList.add('open');
}
function closeModal(id){document.getElementById('modal-'+id).classList.remove('open');}

/* ── LEAVE ── */
let leaveFilter='all';

function filterLeave(f, btn){
  leaveFilter=f;
  document.querySelectorAll('.lf-pill').forEach(p=>p.classList.remove('active'));
  btn.classList.add('active');
  renderLeaveTable();
}

function renderLeaveMetrics(){
  const t=I[lang];
  const reqs=t.leaveRequests||[];
  const pending=reqs.filter(r=>r.status==='pending').length;
  const approved=reqs.filter(r=>r.status==='approved').length;
  const totalDays=reqs.filter(r=>r.status==='approved').reduce((s,r)=>s+r.days,0);
  const el=document.getElementById('leave-metrics');
  if(!el)return;
  el.innerHTML=`
    <div class="mc"><div class="mc-label" data-i18n="filterPending">${t.filterPending}</div><div class="mc-val warn">${pending}</div><div class="mc-sub warn">${t.leaveSubtitle?t.leavePending:''}</div></div>
    <div class="mc"><div class="mc-label" data-i18n="filterApproved">${t.filterApproved}</div><div class="mc-val up">${approved}</div><div class="mc-sub up">${t.leaveApproved}</div></div>
    <div class="mc"><div class="mc-label">Jours approuvés</div><div class="mc-val">${totalDays}</div><div class="mc-sub" style="color:var(--muted);">cette année</div></div>
    <div class="mc"><div class="mc-label">${t.navTeam}</div><div class="mc-val">${getStoreEmps(activeStoreId).length}</div><div class="mc-sub" style="color:var(--muted);">${t.metricStaff}</div></div>`;
  const pc=document.getElementById('pending-count');
  if(pc)pc.textContent=pending;
  document.getElementById('leave-badge').textContent=pending;
}

function renderLeaveTable(){
  const t=I[lang];
  const tbody=document.getElementById('leave-tbody');
  if(!tbody)return;
  const storeEmpIds=getStoreEmps(activeStoreId).map(e=>e.id);
  let reqs=(t.leaveRequests||[]).filter(r=>storeEmpIds.includes(r.empId));
  if(leaveFilter!=='all') reqs=reqs.filter(r=>r.status===leaveFilter);
  const badgeCls={pending:'lb-pending',approved:'lb-approved',rejected:'lb-rejected'};
  const badgeLbl={pending:t.leavePending,approved:t.leaveApproved,rejected:t.leaveRejected};
  tbody.innerHTML=reqs.map(r=>{
    const emp=employees.find(e=>e.id===r.empId);
    if(!emp)return'';
    return `<tr id="leave-row-${r.id}">
      <td><div style="display:flex;align-items:center;gap:8px;">
        <div style="width:26px;height:26px;border-radius:50%;background:${emp.color}22;color:${emp.color};display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:600;flex-shrink:0;">${emp.name.split(' ').map(x=>x[0]).join('')}</div>
        <div><div style="font-size:13px;font-weight:500;">${emp.name}</div><div style="font-size:11px;color:var(--muted);">${emp.role}</div></div>
      </div></td>
      <td><span style="font-size:12px;font-weight:500;">${r.type}</span></td>
      <td style="font-size:12px;color:var(--muted);white-space:nowrap;">${r.from} → ${r.to}</td>
      <td style="font-size:13px;font-weight:600;">${r.days}</td>
      <td style="font-size:12px;color:var(--muted);font-style:${r.note?'normal':'italic'};max-width:140px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${r.note||'—'}</td>
      <td><span class="leave-badge ${badgeCls[r.status]}"><span class="leave-type-dot"></span>${badgeLbl[r.status]}</span></td>
      <td>${r.status==='pending'?`
        <span class="action-icon approve" title="${t.tooltipApprove}" onclick="actLeave(${r.id},'approved')">✓</span>
        <span class="action-icon reject" title="${t.tooltipReject}" onclick="actLeave(${r.id},'rejected')">✕</span>
      `:`<span style="font-size:12px;color:var(--muted);">—</span>`}</td>
    </tr>`;
  }).join('');
  if(reqs.length===0) tbody.innerHTML=`<tr><td colspan="7" style="text-align:center;padding:24px;color:var(--muted);font-size:13px;">—</td></tr>`;
}

function actLeave(id, newStatus){
  const t=I[lang];
  // update in all languages
  Object.values(I).forEach(lng=>{
    const req=(lng.leaveRequests||[]).find(r=>r.id===id);
    if(req) req.status=newStatus;
  });
  renderLeaveTable();
  renderLeaveMetrics();
  showManagerToast(newStatus==='approved'?t.toastApproved:t.toastRejected);
}

function renderLeaveSummary(){
  const t=I[lang];
  const grid=document.getElementById('leave-summary-grid');
  if(!grid)return;
  const emps=getStoreEmps(activeStoreId).slice(0,6);
  grid.innerHTML=emps.map(emp=>{
    const bal=(t.empBalances||[]).find(b=>b.empId===emp.id)||{paid:18,rtt:3,sick:2};
    const paidPct=Math.round(bal.paid/30*100);
    const rttPct=Math.round(bal.rtt/10*100);
    const sickPct=Math.round(bal.sick/10*100);
    return `<div class="lsg-card">
      <div class="lsg-emp">
        <div style="width:28px;height:28px;border-radius:50%;background:${emp.color}22;color:${emp.color};display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:600;flex-shrink:0;">${emp.name.split(' ').map(x=>x[0]).join('')}</div>
        <div><div class="lsg-name">${emp.name}</div><div class="lsg-role">${emp.role}</div></div>
      </div>
      <div class="lsg-bars">
        <div class="lsg-bar-row">
          <div class="lsg-bar-lbl">${t.lblPaid}</div>
          <div class="lsg-bar-track"><div class="lsg-bar-fill" style="width:${paidPct}%;background:var(--accent);"></div></div>
          <div class="lsg-bar-val">${bal.paid}j</div>
        </div>
        <div class="lsg-bar-row">
          <div class="lsg-bar-lbl">${t.lblRTT}</div>
          <div class="lsg-bar-track"><div class="lsg-bar-fill" style="width:${rttPct}%;background:var(--accent2);"></div></div>
          <div class="lsg-bar-val">${bal.rtt}j</div>
        </div>
        <div class="lsg-bar-row">
          <div class="lsg-bar-lbl">${t.lblSick}</div>
          <div class="lsg-bar-track"><div class="lsg-bar-fill" style="width:${sickPct}%;background:var(--accent3);"></div></div>
          <div class="lsg-bar-val">${bal.sick}j</div>
        </div>
      </div>
    </div>`;
  }).join('');
}

function exportLeave(){
  showManagerToast('CSV exporté ✓');
