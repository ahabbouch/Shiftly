<!DOCTYPE html>
<html lang="fr" dir="ltr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Shiftly — Manager</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=Noto+Sans+Arabic:wght@400;500;600&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#0f0f11;--bg2:#17171a;--bg3:#1e1e23;--bg4:#252529;
  --border:rgba(255,255,255,0.07);--border2:rgba(255,255,255,0.13);
  --text:#f0f0f2;--muted:#7a7a85;--subtle:#4a4a55;
  --accent:#6c6fff;--accent2:#4ade80;--accent3:#fb923c;
  --danger:#f87171;--warning:#fbbf24;
  --r:10px;--rl:14px;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'DM Sans','Noto Sans Arabic',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;font-size:14px;}

/* ── LANG BAR ── */
.lang-bar{position:fixed;top:0;left:0;right:0;z-index:999;background:var(--bg2);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:flex-end;padding:5px 16px;height:36px;}
[dir="rtl"] .lang-bar{justify-content:flex-start;}
.lang-wrap{position:relative;}
.lang-btn{display:flex;align-items:center;gap:6px;padding:5px 12px;border-radius:20px;border:1px solid var(--border2);background:var(--bg3);color:var(--muted);font-size:12px;font-weight:500;cursor:pointer;font-family:inherit;transition:all .15s;}
.lang-btn:hover{color:var(--text);}
.lang-dd{position:absolute;top:calc(100%+6px);right:0;background:var(--bg3);border:1px solid var(--border2);border-radius:12px;overflow:hidden;z-index:600;min-width:155px;display:none;box-shadow:0 8px 24px rgba(0,0,0,.5);}
[dir="rtl"] .lang-dd{right:auto;left:0;}
.lang-dd.open{display:block;}
.lang-opt{display:flex;align-items:center;gap:10px;padding:9px 13px;font-size:13px;font-weight:500;color:var(--muted);cursor:pointer;transition:background .12s;border-bottom:1px solid var(--border);}
.lang-opt:last-child{border-bottom:none;}
.lang-opt:hover{background:rgba(255,255,255,.05);color:var(--text);}
.lang-opt.active{color:var(--text);background:rgba(108,111,255,.12);}
.lchk{margin-left:auto;color:var(--accent);font-size:12px;}
[dir="rtl"] .lchk{margin-left:0;margin-right:auto;}

/* ── SIDEBAR ── */
.sidebar{position:fixed;left:0;top:36px;bottom:0;width:230px;background:var(--bg2);border-right:1px solid var(--border);display:flex;flex-direction:column;z-index:100;}
[dir="rtl"] .sidebar{left:auto;right:0;border-right:none;border-left:1px solid var(--border);}
.sidebar-logo{padding:18px 18px 14px;font-size:18px;font-weight:600;letter-spacing:-.5px;border-bottom:1px solid var(--border);flex-shrink:0;}
.sidebar-logo span{color:var(--accent);}

/* STORE SWITCHER */
.store-switcher{margin:10px 10px 4px;flex-shrink:0;}
.store-switcher-label{font-size:10px;font-weight:500;color:var(--muted);text-transform:uppercase;letter-spacing:.06em;padding:0 4px;margin-bottom:6px;}
.store-btn{width:100%;display:flex;align-items:center;gap:10px;padding:9px 10px;border-radius:var(--r);background:var(--bg3);border:1px solid var(--border2);cursor:pointer;transition:all .15s;margin-bottom:4px;text-align:left;}
.store-btn:hover{border-color:rgba(255,255,255,.2);}
.store-btn.active{border-color:var(--accent);background:rgba(108,111,255,.08);}
.store-dot{width:32px;height:32px;border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;flex-shrink:0;color:#fff;}
.store-info-col{flex:1;min-width:0;}
.store-btn-name{font-size:13px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.store-btn-addr{font-size:11px;color:var(--muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-top:1px;}
.store-active-dot{width:7px;height:7px;border-radius:50%;background:var(--accent2);flex-shrink:0;}
.add-store-btn{width:100%;display:flex;align-items:center;gap:8px;padding:8px 10px;border-radius:var(--r);background:transparent;border:1px dashed var(--subtle);cursor:pointer;color:var(--muted);font-size:12px;font-weight:500;font-family:inherit;transition:all .15s;margin-bottom:2px;}
.add-store-btn:hover{border-color:var(--accent);color:var(--accent);}

/* NAV */
.nav{padding:6px 10px;flex:1;overflow-y:auto;}
.nav-section{font-size:10px;font-weight:500;color:var(--subtle);text-transform:uppercase;letter-spacing:.06em;padding:8px 6px 4px;}
.nav-item{display:flex;align-items:center;gap:9px;padding:8px 10px;border-radius:8px;color:var(--muted);font-size:13px;font-weight:500;cursor:pointer;transition:all .15s;margin-bottom:1px;}
.nav-item:hover{background:var(--bg3);color:var(--text);}
.nav-item.active{background:rgba(108,111,255,.12);color:var(--accent);}
.nav-icon{font-size:15px;width:18px;text-align:center;}
.nav-badge{margin-left:auto;background:var(--danger);color:#fff;font-size:10px;padding:1px 5px;border-radius:20px;font-weight:600;}
[dir="rtl"] .nav-badge{margin-left:0;margin-right:auto;}
.sidebar-footer{padding:10px;border-top:1px solid var(--border);display:flex;align-items:center;gap:9px;flex-shrink:0;}
.user-av{width:28px;height:28px;border-radius:50%;background:linear-gradient(135deg,var(--accent),#a78bfa);display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:600;}

/* ── MAIN ── */
.main{margin-left:230px;margin-top:36px;min-height:100vh;}
[dir="rtl"] .main{margin-left:0;margin-right:230px;}
.topbar{padding:14px 22px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;background:var(--bg);position:sticky;top:36px;z-index:50;}
.page-title{font-size:17px;font-weight:600;letter-spacing:-.3px;}
.topbar-right{display:flex;gap:8px;align-items:center;}
.btn{padding:7px 14px;border-radius:8px;font-size:13px;font-weight:500;border:1px solid var(--border2);background:var(--bg3);color:var(--text);cursor:pointer;transition:all .15s;font-family:inherit;}
.btn:hover{border-color:rgba(255,255,255,.2);}
.btn-primary{background:var(--accent);border-color:var(--accent);color:#fff;}
.btn-primary:hover{background:#5a5df0;}
.btn-sm{padding:5px 10px;font-size:12px;}
.btn-danger{background:rgba(248,113,113,.1);border-color:rgba(248,113,113,.3);color:var(--danger);}
.btn-danger:hover{background:rgba(248,113,113,.2);}
.content{padding:20px 22px;}

/* ── PANELS ── */
.panel{display:none;}.panel.active{display:block;}

/* ── METRICS ── */
.metrics{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:20px;}
.mc{background:var(--bg2);border:1px solid var(--border);border-radius:var(--rl);padding:15px 17px;}
.mc-label{font-size:11px;color:var(--muted);margin-bottom:5px;font-weight:500;text-transform:uppercase;letter-spacing:.04em;}
.mc-val{font-size:24px;font-weight:600;letter-spacing:-.5px;margin-bottom:2px;}
.mc-sub{font-size:12px;color:var(--muted);}
.up{color:var(--accent2)!important;}.warn{color:var(--warning)!important;}.danger{color:var(--danger)!important;}

/* ── SCHEDULE ── */
.week-nav{display:flex;align-items:center;gap:10px;margin-bottom:12px;}
.week-lbl{font-size:14px;font-weight:600;}
.wbtn{background:var(--bg3);border:1px solid var(--border);border-radius:8px;color:var(--muted);padding:5px 11px;cursor:pointer;font-family:inherit;font-size:13px;}
.today-badge{font-size:11px;background:rgba(108,111,255,.15);color:var(--accent);padding:3px 10px;border-radius:20px;font-weight:500;border:1px solid rgba(108,111,255,.3);}
.sched-wrap{background:var(--bg2);border:1px solid var(--border);border-radius:var(--rl);overflow:hidden;margin-bottom:16px;overflow-x:auto;}
.sched-header{display:grid;grid-template-columns:148px repeat(7,1fr);border-bottom:1px solid var(--border);min-width:660px;}
.sh-c{padding:9px 7px;text-align:center;font-size:12px;color:var(--muted);font-weight:500;border-right:1px solid var(--border);}
.sh-c:last-child{border-right:none;}
.sh-c.today{color:var(--accent);background:rgba(108,111,255,.06);}
.sh-day{font-size:12px;font-weight:600;}.sh-date{font-size:11px;}
.sched-row{display:grid;grid-template-columns:148px repeat(7,1fr);border-bottom:1px solid var(--border);min-width:660px;}
.sched-row:last-child{border-bottom:none;}
.emp-c{padding:9px 11px;border-right:1px solid var(--border);display:flex;align-items:center;gap:7px;}
.eav{width:26px;height:26px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:600;flex-shrink:0;}
.ename{font-size:12px;font-weight:500;}
.erole{font-size:10px;color:var(--muted);}
.shared-tag{font-size:9px;font-weight:600;padding:1px 5px;border-radius:20px;background:rgba(251,146,60,.15);color:var(--accent3);border:1px solid rgba(251,146,60,.25);margin-top:2px;display:inline-block;}
.shift-c{padding:5px 4px;border-right:1px solid var(--border);display:flex;align-items:center;justify-content:center;cursor:pointer;}
.shift-c:last-child{border-right:none;}
.shift-c.today{background:rgba(108,111,255,.04);}
.sb{width:100%;padding:3px 5px;border-radius:5px;font-size:10px;font-weight:500;text-align:center;line-height:1.4;}
.sm{background:rgba(74,222,128,.12);color:var(--accent2);border:1px solid rgba(74,222,128,.2);}
.sa{background:rgba(108,111,255,.12);color:var(--accent);border:1px solid rgba(108,111,255,.2);}
.sf{background:rgba(251,146,60,.12);color:var(--accent3);border:1px solid rgba(251,146,60,.2);}
.se{width:100%;height:27px;border-radius:5px;border:1px dashed rgba(255,255,255,.08);display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,.1);font-size:14px;cursor:pointer;transition:all .15s;}
.se:hover{border-color:var(--accent);color:var(--accent);background:rgba(108,111,255,.06);}

/* ── CARDS ── */
.two-col{display:grid;grid-template-columns:1fr 290px;gap:14px;}
.card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--rl);overflow:hidden;}
.card-hdr{padding:11px 15px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;}
.card-title{font-size:13px;font-weight:600;}
.alert-row{padding:10px 15px;border-bottom:1px solid var(--border);display:flex;gap:9px;align-items:flex-start;}
.alert-row:last-child{border-bottom:none;}
.adot{width:7px;height:7px;border-radius:50%;margin-top:5px;flex-shrink:0;}
.amsg{font-size:13px;flex:1;line-height:1.5;}
.aact{font-size:11px;color:var(--accent);cursor:pointer;font-weight:500;margin-top:3px;}
.qs{padding:10px 15px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;}
.qs:last-child{border-bottom:none;}
.qs-l{font-size:13px;color:var(--muted);}
.qs-v{font-size:13px;font-weight:600;}

/* ── TEAM TABLE ── */
.table-wrap{background:var(--bg2);border:1px solid var(--border);border-radius:var(--rl);overflow:hidden;}
.data-table{width:100%;border-collapse:collapse;font-size:13px;}
.data-table th{text-align:left;padding:9px 15px;font-size:11px;color:var(--muted);font-weight:500;border-bottom:1px solid var(--border);text-transform:uppercase;letter-spacing:.04em;}
.data-table td{padding:11px 15px;border-bottom:1px solid var(--border);vertical-align:middle;}
.data-table tr:last-child td{border-bottom:none;}
.data-table tr:hover td{background:rgba(255,255,255,.02);}
.store-pill{font-size:11px;font-weight:500;padding:2px 8px;border-radius:20px;display:inline-flex;align-items:center;gap:4px;margin:2px 3px 2px 0;}
.emp-cell-row{display:flex;align-items:center;gap:9px;}

/* ── SETTINGS / STORES ── */
.stores-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:14px;margin-bottom:18px;}
.store-card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--rl);overflow:hidden;transition:border-color .2s;}
.store-card:hover{border-color:var(--border2);}
.store-card.active-store{border-color:var(--accent);}
.sc-top{padding:14px 16px;display:flex;align-items:center;gap:12px;border-bottom:1px solid var(--border);}
.sc-icon{width:40px;height:40px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:700;color:#fff;flex-shrink:0;}
.sc-name{font-size:14px;font-weight:600;}
.sc-type{font-size:12px;color:var(--muted);margin-top:2px;}
.sc-body{padding:12px 16px;}
.sc-field{margin-bottom:10px;}
.sc-field:last-child{margin-bottom:0;}
.sc-field-label{font-size:11px;color:var(--muted);font-weight:500;text-transform:uppercase;letter-spacing:.04em;margin-bottom:4px;}
.sc-field-val{font-size:13px;font-weight:500;display:flex;align-items:center;gap:8px;}
.sc-field-val.addr{color:var(--accent);font-size:12px;}
.sc-actions{padding:10px 16px;border-top:1px solid var(--border);display:flex;gap:8px;}
.radius-badge{font-size:11px;padding:2px 8px;border-radius:20px;background:rgba(108,111,255,.12);color:var(--accent);border:1px solid rgba(108,111,255,.25);font-weight:500;}
.add-store-card{background:var(--bg2);border:2px dashed var(--subtle);border-radius:var(--rl);display:flex;flex-direction:column;align-items:center;justify-content:center;padding:32px;cursor:pointer;transition:all .2s;min-height:200px;}
.add-store-card:hover{border-color:var(--accent);background:rgba(108,111,255,.04);}
.add-store-card-icon{font-size:28px;margin-bottom:10px;opacity:.5;}
.add-store-card-text{font-size:13px;font-weight:500;color:var(--muted);}
.add-store-card:hover .add-store-card-icon,.add-store-card:hover .add-store-card-text{opacity:1;color:var(--accent);}

/* ── MODAL ── */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.75);display:flex;align-items:center;justify-content:center;z-index:400;opacity:0;pointer-events:none;transition:opacity .2s;}
.modal-overlay.open{opacity:1;pointer-events:all;}
.modal{background:var(--bg2);border:1px solid var(--border2);border-radius:16px;padding:0;width:460px;max-height:90vh;overflow-y:auto;transform:translateY(10px);transition:transform .2s;}
.modal-overlay.open .modal{transform:translateY(0);}
.modal-hdr{padding:18px 22px 14px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;background:var(--bg2);z-index:1;}
.modal-title{font-size:16px;font-weight:600;}
.modal-close{width:28px;height:28px;border-radius:50%;background:var(--bg3);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:14px;color:var(--muted);}
.modal-body{padding:18px 22px;}
.form-group{margin-bottom:14px;}
.form-label{font-size:12px;color:var(--muted);font-weight:500;text-transform:uppercase;letter-spacing:.04em;margin-bottom:5px;display:block;}
.form-input,.form-select,.form-textarea{width:100%;padding:9px 12px;border-radius:8px;background:var(--bg3);border:1px solid var(--border2);color:var(--text);font-family:inherit;font-size:13px;outline:none;transition:border-color .15s;}
.form-input:focus,.form-select:focus,.form-textarea:focus{border-color:var(--accent);}
.form-select option,.form-textarea{background:var(--bg3);}
.form-textarea{resize:vertical;min-height:60px;}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.form-hint{font-size:11px;color:var(--muted);margin-top:4px;}
.modal-footer{padding:14px 22px;border-top:1px solid var(--border);display:flex;gap:10px;justify-content:flex-end;position:sticky;bottom:0;background:var(--bg2);}
[dir="rtl"] .modal-footer{justify-content:flex-start;}

/* COLOR PICKER */
.color-row{display:flex;gap:8px;flex-wrap:wrap;}
.color-swatch{width:28px;height:28px;border-radius:7px;cursor:pointer;border:2px solid transparent;transition:all .15s;}
.color-swatch.selected,.color-swatch:hover{border-color:#fff;transform:scale(1.1);}

/* GEO TABLE */
.geo-table-wrap{background:var(--bg2);border:1px solid var(--border);border-radius:var(--rl);overflow:hidden;margin-bottom:16px;}
.geo-table{width:100%;border-collapse:collapse;font-size:13px;}
.geo-table th{text-align:left;padding:9px 15px;font-size:11px;color:var(--muted);font-weight:500;border-bottom:1px solid var(--border);text-transform:uppercase;letter-spacing:.04em;}
.geo-table td{padding:11px 15px;border-bottom:1px solid var(--border);vertical-align:middle;}
.geo-table tr:last-child td{border-bottom:none;}
.geo-table tr:hover td{background:rgba(255,255,255,.02);}
.geo-badge{display:inline-flex;align-items:center;gap:5px;font-size:11px;font-weight:500;padding:3px 9px;border-radius:20px;}
.geo-ok{background:rgba(74,222,128,.1);color:var(--accent2);border:1px solid rgba(74,222,128,.2);}
.geo-out{background:rgba(248,113,113,.1);color:var(--danger);border:1px solid rgba(248,113,113,.2);}
.geo-pending{background:rgba(122,122,133,.1);color:var(--muted);border:1px solid var(--border);}
.gdot{width:6px;height:6px;border-radius:50%;background:currentColor;}
.dist-pill{font-size:11px;color:var(--muted);background:var(--bg3);padding:2px 7px;border-radius:20px;border:1px solid var(--border);}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}
.live{width:7px;height:7px;border-radius:50%;background:var(--accent2);display:inline-block;animation:blink 2s ease-in-out infinite;}

/* RTL adjustments */
[dir="rtl"] .emp-c,[dir="rtl"] .shift-c,[dir="rtl"] .sh-c{border-right:none;border-left:1px solid var(--border);}
[dir="rtl"] .sh-c:last-child,[dir="rtl"] .shift-c:last-child{border-left:none;}
[dir="rtl"] .geo-table th,[dir="rtl"] .geo-table td,[dir="rtl"] .data-table th,[dir="rtl"] .data-table td{text-align:right;}

/* ── LEAVE PANEL ── */
.leave-metrics{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:18px;}
.leave-filter-row{display:flex;gap:8px;margin-bottom:14px;flex-wrap:wrap;}
.lf-pill{padding:6px 13px;border-radius:20px;font-size:12px;font-weight:500;border:1px solid var(--border);background:var(--bg3);color:var(--muted);cursor:pointer;font-family:inherit;transition:all .15s;}
.lf-pill:hover{color:var(--text);border-color:var(--border2);}
.lf-pill.active{background:rgba(108,111,255,.12);border-color:var(--accent);color:var(--accent);}
.leave-table-wrap{background:var(--bg2);border:1px solid var(--border);border-radius:var(--rl);overflow:hidden;margin-bottom:16px;}
.leave-table{width:100%;border-collapse:collapse;font-size:13px;}
.leave-table th{text-align:left;padding:9px 15px;font-size:11px;color:var(--muted);font-weight:500;border-bottom:1px solid var(--border);text-transform:uppercase;letter-spacing:.04em;}
.leave-table td{padding:11px 15px;border-bottom:1px solid var(--border);vertical-align:middle;}
.leave-table tr:last-child td{border-bottom:none;}
.leave-table tr:hover td{background:rgba(255,255,255,.02);}
.leave-badge{display:inline-flex;align-items:center;gap:5px;font-size:11px;font-weight:500;padding:3px 9px;border-radius:20px;}
.lb-pending{background:rgba(251,191,36,.1);color:var(--warning);border:1px solid rgba(251,191,36,.25);}
.lb-approved{background:rgba(74,222,128,.1);color:var(--accent2);border:1px solid rgba(74,222,128,.2);}
.lb-rejected{background:rgba(248,113,113,.1);color:var(--danger);border:1px solid rgba(248,113,113,.2);}
.leave-type-dot{width:7px;height:7px;border-radius:50%;background:currentColor;flex-shrink:0;}
.action-icon{width:28px;height:28px;border-radius:8px;border:1px solid var(--border);background:var(--bg3);display:inline-flex;align-items:center;justify-content:center;font-size:13px;cursor:pointer;transition:all .15s;margin-right:4px;}
.action-icon:hover{border-color:var(--border2);background:var(--bg4);}
.action-icon.approve:hover{background:rgba(74,222,128,.1);border-color:rgba(74,222,128,.3);color:var(--accent2);}
.action-icon.reject:hover{background:rgba(248,113,113,.1);border-color:rgba(248,113,113,.3);color:var(--danger);}
.leave-summary-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:16px;}
.lsg-card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--rl);padding:14px 16px;}
.lsg-emp{display:flex;align-items:center;gap:9px;margin-bottom:10px;}
.lsg-name{font-size:13px;font-weight:500;}
.lsg-role{font-size:11px;color:var(--muted);}
.lsg-bars{display:flex;flex-direction:column;gap:5px;}
.lsg-bar-row{display:flex;align-items:center;gap:8px;font-size:11px;}
.lsg-bar-lbl{color:var(--muted);min-width:60px;}
.lsg-bar-track{flex:1;height:4px;background:var(--bg3);border-radius:2px;}
.lsg-bar-fill{height:100%;border-radius:2px;}
.lsg-bar-val{color:var(--muted);min-width:24px;text-align:right;}
