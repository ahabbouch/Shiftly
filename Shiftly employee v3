<!DOCTYPE html>
<html lang="fr" dir="ltr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Shiftly — Employé</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=Noto+Sans+Arabic:wght@400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --bg:#f5f4f1;--card:#fff;--border:rgba(0,0,0,0.07);
  --text:#1a1a1c;--muted:#8a8a95;
  --accent:#6c6fff;--accent-light:rgba(108,111,255,0.10);
  --green:#16a34a;--green-light:rgba(22,163,74,0.10);
  --orange:#ea580c;--orange-light:rgba(234,88,12,0.10);
  --red:#dc2626;--red-light:rgba(220,38,38,0.10);
  --radius:16px;--radius-sm:10px;
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
body{
  font-family:'DM Sans','Noto Sans Arabic',sans-serif;
  background:#1e1e23;
  display:flex;align-items:center;justify-content:center;
  min-height:100vh;padding:20px;
}

/* PHONE SHELL */
.phone{
  width:375px;background:var(--bg);
  border-radius:44px;overflow:hidden;
  box-shadow:0 40px 80px rgba(0,0,0,0.5),0 0 0 1px rgba(255,255,255,0.06);
  display:flex;flex-direction:column;min-height:820px;
  position:relative;
}
.notch{background:#1a1a1c;height:44px;display:flex;align-items:center;justify-content:center;border-radius:44px 44px 0 0;flex-shrink:0;}
.notch-pill{width:120px;height:34px;background:#000;border-radius:20px;}
.phone-body{flex:1;overflow:hidden;display:flex;flex-direction:column;}

/* ─── TOP BAR (inside phone) ─── */
.phone-topbar{
  display:flex;align-items:center;justify-content:space-between;
  padding:8px 16px 6px;
  background:var(--bg);
  border-bottom:1px solid var(--border);
  flex-shrink:0;position:relative;z-index:50;
}
.phone-topbar-left{font-size:15px;font-weight:600;letter-spacing:-.3px;}
.phone-topbar-left span{color:var(--accent);}
.status-icons{font-size:11px;color:var(--text);opacity:.55;letter-spacing:1px;}

/* LANG BUTTON inside phone */
.lang-pill{
  display:flex;align-items:center;gap:5px;
  padding:5px 10px;border-radius:20px;
  border:1px solid var(--border);background:var(--card);
  font-size:12px;font-weight:500;color:var(--muted);
  cursor:pointer;transition:all .15s;position:relative;
}
.lang-pill:hover{border-color:var(--accent);color:var(--accent);}
.lang-flag-sm{font-size:14px;}

/* LANG DROPDOWN inside phone */
.lang-dropdown{
  position:absolute;top:calc(100% + 6px);right:0;
  background:#fff;border:1px solid var(--border);
  border-radius:12px;overflow:hidden;z-index:200;
  min-width:155px;display:none;
  box-shadow:0 8px 24px rgba(0,0,0,0.12);
}
[dir="rtl"] .lang-dropdown{right:auto;left:0;}
.lang-dropdown.open{display:block;}
.lang-opt{
  display:flex;align-items:center;gap:10px;
  padding:10px 13px;font-size:13px;font-weight:500;
  color:var(--muted);cursor:pointer;transition:background .12s;
  border-bottom:1px solid var(--border);
}
.lang-opt:last-child{border-bottom:none;}
.lang-opt:hover{background:#f5f4f1;color:var(--text);}
.lang-opt.active{color:var(--accent);background:var(--accent-light);}
.lang-chk{margin-left:auto;color:var(--accent);font-size:12px;}
[dir="rtl"] .lang-chk{margin-left:0;margin-right:auto;}

/* SCREENS */
.screen{display:none;flex-direction:column;flex:1;overflow-y:auto;}
.screen.active{display:flex;}
.screen::-webkit-scrollbar{display:none;}

/* STATUS ROW (time + signal) */
.status-bar{padding:10px 20px 4px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;}
.status-time{font-size:15px;font-weight:600;}

/* HOME */
.home-header{padding:6px 20px 12px;flex-shrink:0;}
.greeting{font-size:13px;color:var(--muted);}
.greeting-name{font-size:22px;font-weight:600;letter-spacing:-.5px;margin-top:2px;}

/* NEXT SHIFT CARD */
.next-shift-card{
  margin:0 16px 12px;background:var(--accent);
  border-radius:var(--radius);padding:18px 20px;
  color:#fff;flex-shrink:0;cursor:pointer;
  transition:transform .15s;position:relative;overflow:hidden;
}
.next-shift-card:active{transform:scale(.98);}
.nsc-label{font-size:11px;opacity:.75;font-weight:500;text-transform:uppercase;letter-spacing:.06em;margin-bottom:5px;}
.nsc-time{font-size:26px;font-weight:600;letter-spacing:-.5px;margin-bottom:2px;}
.nsc-day{font-size:13px;opacity:.85;margin-bottom:12px;}
.nsc-bottom{display:flex;align-items:center;justify-content:space-between;}
.nsc-badge{background:rgba(255,255,255,.2);padding:4px 11px;border-radius:20px;font-size:12px;font-weight:500;}
.nsc-deco{position:absolute;right:-20px;top:-20px;width:110px;height:110px;border-radius:50%;background:rgba(255,255,255,.07);}
.nsc-deco2{position:absolute;right:18px;bottom:-28px;width:74px;height:74px;border-radius:50%;background:rgba(255,255,255,.05);}

/* CLOCK IN CARD */
.clockin-card{
  margin:0 16px 12px;background:var(--card);
  border-radius:var(--radius);padding:14px 16px;
  border:1px solid var(--border);flex-shrink:0;
}
.cc-label{font-size:11px;color:var(--muted);font-weight:500;text-transform:uppercase;letter-spacing:.06em;margin-bottom:10px;}

/* STORE ADDRESS ROW */
.store-row{
  display:flex;align-items:center;gap:8px;
  padding:9px 12px;border-radius:var(--radius-sm);
  background:#f5f4f1;border:1px solid var(--border);
  margin-bottom:10px;cursor:pointer;
}
.store-icon{font-size:14px;flex-shrink:0;}
.store-info{flex:1;min-width:0;}
.store-name{font-size:12px;font-weight:600;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.store-addr{font-size:11px;color:var(--muted);margin-top:1px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.store-radius{font-size:11px;font-weight:500;color:var(--accent);background:var(--accent-light);padding:2px 7px;border-radius:20px;flex-shrink:0;}

/* CLOCK STATUS */
.cc-status{display:flex;align-items:center;gap:8px;margin-bottom:8px;}
.cc-dot{width:9px;height:9px;border-radius:50%;background:var(--muted);flex-shrink:0;}
.cc-status-text{font-size:13px;font-weight:500;flex:1;}
.cc-time{font-size:12px;color:var(--muted);}

/* GEO ROW */
.geo-row{
  display:flex;align-items:center;gap:7px;
  font-size:12px;padding:7px 10px;border-radius:8px;
  margin-bottom:8px;transition:all .3s;
}
.geo-row.checking{background:rgba(0,0,0,.04);color:var(--muted);}
.geo-row.in-range{background:var(--green-light);color:var(--green);}
.geo-row.out-range{background:var(--red-light);color:var(--red);}
.geo-row.denied{background:var(--orange-light);color:var(--orange);}
.geo-icon{font-size:14px;flex-shrink:0;}
.geo-text{flex:1;font-weight:500;}
.geo-dist-badge{font-size:11px;font-weight:600;padding:2px 8px;border-radius:20px;background:rgba(0,0,0,.06);color:inherit;}
@keyframes pulse-dot{0%,100%{opacity:1}50%{opacity:.3}}
.pulse{animation:pulse-dot 1.2s ease-in-out infinite;}

/* MAP MINI */
.map-wrap{
  border-radius:10px;overflow:hidden;
  border:1px solid var(--border);margin-bottom:8px;
  height:100px;position:relative;
  background:#dce8dc;display:none;
}
.map-wrap.show{display:block;}
.map-label-bar{
  position:absolute;bottom:0;left:0;right:0;
  background:rgba(0,0,0,.45);padding:4px 10px;
  font-size:10px;color:#fff;font-weight:500;
}

/* CLOCK BTN */
.clock-btn{
  width:100%;padding:12px;border-radius:var(--radius-sm);
  background:var(--green);color:#fff;font-size:14px;font-weight:600;
  border:none;cursor:pointer;font-family:inherit;
  transition:all .15s;display:flex;align-items:center;justify-content:center;gap:8px;
}
.clock-btn:active{transform:scale(.98);}
.clock-btn:disabled{background:#ccc;cursor:not-allowed;}
.clock-btn.clocked-in{background:var(--red);}

/* SECTION */
.section-hdr{padding:4px 20px 8px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0;}
.section-title{font-size:15px;font-weight:600;}
.section-link{font-size:13px;color:var(--accent);font-weight:500;cursor:pointer;}

/* WEEK LIST */
.week-list{padding:0 16px;flex-shrink:0;}
.shift-item{
  background:var(--card);border-radius:var(--radius-sm);
  padding:11px 13px;margin-bottom:7px;border:1px solid var(--border);
  display:flex;align-items:center;gap:11px;cursor:pointer;transition:all .15s;
}
.shift-item.today{border-color:var(--accent);background:var(--accent-light);}
.day-col{text-align:center;min-width:32px;}
.day-name{font-size:10px;color:var(--muted);font-weight:500;text-transform:uppercase;}
.day-num{font-size:18px;font-weight:600;letter-spacing:-.5px;}
.day-num.tnow{color:var(--accent);}
.vdivider{width:1px;height:32px;background:var(--border);flex-shrink:0;}
.shift-info{flex:1;}
.shift-time{font-size:13px;font-weight:500;}
.shift-role-lbl{font-size:11px;color:var(--muted);margin-top:1px;}
.pill{font-size:11px;font-weight:600;padding:3px 9px;border-radius:20px;white-space:nowrap;}
.p-done{background:var(--green-light);color:var(--green);}
.p-today{background:var(--orange-light);color:var(--orange);}
.p-off{background:rgba(0,0,0,.05);color:var(--muted);}
.p-pending{background:var(--orange-light);color:var(--orange);}
.p-ok{background:var(--green-light);color:var(--green);}

/* BOTTOM NAV */
.bottom-nav{display:flex;background:var(--card);border-top:1px solid var(--border);padding:10px 0 20px;flex-shrink:0;}
.nav-tab{flex:1;display:flex;flex-direction:column;align-items:center;gap:3px;cursor:pointer;padding:4px 0;}
.nav-tab-icon{font-size:20px;}
.nav-tab-label{font-size:10px;font-weight:500;color:var(--muted);}
.nav-tab.active .nav-tab-label{color:var(--accent);}

/* DETAIL */
.detail-hdr{padding:11px 18px;display:flex;align-items:center;gap:11px;flex-shrink:0;}
.back-btn{width:32px;height:32px;border-radius:50%;background:var(--card);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:15px;flex-shrink:0;}
.detail-title{font-size:16px;font-weight:600;}
.detail-hero{margin:0 16px 12px;background:var(--card);border-radius:var(--radius);border:1px solid var(--border);padding:18px;flex-shrink:0;}
.dh-day{font-size:12px;color:var(--muted);font-weight:500;margin-bottom:2px;}
.dh-time{font-size:28px;font-weight:600;letter-spacing:-1px;margin-bottom:2px;}
.dh-dur{font-size:12px;color:var(--muted);margin-bottom:13px;}
.dh-tags{display:flex;gap:7px;flex-wrap:wrap;}
.dh-tag{font-size:12px;font-weight:500;padding:3px 10px;border-radius:20px;}
.tag-role{background:var(--accent-light);color:var(--accent);}
.tag-loc{background:rgba(0,0,0,.05);color:var(--muted);}
.detail-actions{padding:0 16px 12px;display:flex;gap:8px;flex-shrink:0;}
.act-btn{flex:1;padding:12px;border-radius:var(--radius-sm);font-size:13px;font-weight:600;border:none;cursor:pointer;font-family:inherit;transition:all .15s;}
.act-btn:active{transform:scale(.98);}
.a-confirm{background:var(--green);color:#fff;}
.a-swap{background:var(--card);color:var(--text);border:1px solid var(--border);}
.a-decline{background:var(--red-light);color:var(--red);}
.info-row{background:var(--card);border:1px solid var(--border);border-radius:var(--radius-sm);padding:12px 14px;display:flex;align-items:center;justify-content:space-between;margin:0 16px 7px;flex-shrink:0;}
.ir-l{font-size:13px;color:var(--muted);}
.ir-v{font-size:13px;font-weight:500;}

/* SWAP */
.swap-sub{padding:0 20px 12px;font-size:13px;color:var(--muted);flex-shrink:0;}
.col-item{margin:0 16px 9px;background:var(--card);border-radius:var(--radius-sm);border:1px solid var(--border);padding:12px 14px;display:flex;align-items:center;gap:10px;cursor:pointer;transition:all .15s;flex-shrink:0;}
.col-item.selected{border-color:var(--accent);background:var(--accent-light);}
.col-av{width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:600;flex-shrink:0;}
.col-name{font-size:13px;font-weight:500;}
.col-avail{font-size:11px;color:var(--green);margin-top:2px;}
.col-avail.busy{color:var(--muted);}
.col-chk{margin-left:auto;width:22px;height:22px;border-radius:50%;border:1.5px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:11px;flex-shrink:0;}
.col-chk.on{background:var(--accent);border-color:var(--accent);color:#fff;}
.send-btn{margin:5px 16px 12px;padding:14px;background:var(--accent);color:#fff;border:none;border-radius:var(--radius-sm);font-size:14px;font-weight:600;cursor:pointer;font-family:inherit;display:block;width:calc(100% - 32px);}
.send-btn:disabled{opacity:.4;cursor:not-allowed;}

/* PROFILE */
.profile-hdr{padding:16px 20px 8px;text-align:center;flex-shrink:0;}
.p-av{width:64px;height:64px;border-radius:50%;background:var(--accent);display:flex;align-items:center;justify-content:center;font-size:20px;font-weight:600;color:#fff;margin:0 auto 9px;}
.p-name{font-size:19px;font-weight:600;}
.p-role{font-size:13px;color:var(--muted);margin-top:2px;}
.stats-row{display:flex;padding:12px 16px;gap:8px;flex-shrink:0;}
.stat-box{flex:1;background:var(--card);border:1px solid var(--border);border-radius:var(--radius-sm);padding:11px 7px;text-align:center;}
.stat-val{font-size:19px;font-weight:600;}
.stat-lbl{font-size:11px;color:var(--muted);margin-top:2px;}
.pref-sec{padding:0 16px 8px;flex-shrink:0;}
.pref-lbl{font-size:11px;color:var(--muted);font-weight:500;text-transform:uppercase;letter-spacing:.05em;margin-bottom:7px;padding-left:2px;}
.pref-item{background:var(--card);border:1px solid var(--border);border-radius:var(--radius-sm);padding:12px 14px;display:flex;align-items:center;justify-content:space-between;margin-bottom:7px;cursor:pointer;}
.pref-item-lbl{font-size:13px;font-weight:500;}
.pref-item-sub{font-size:11px;color:var(--muted);margin-top:2px;}
.toggle{width:38px;height:22px;background:#ddd;border-radius:11px;position:relative;cursor:pointer;transition:background .2s;flex-shrink:0;}
.toggle.on{background:var(--accent);}
.toggle-k{position:absolute;width:16px;height:16px;background:#fff;border-radius:50%;top:3px;left:3px;transition:left .2s;box-shadow:0 1px 3px rgba(0,0,0,.2);}
.toggle.on .toggle-k{left:19px;}

/* RTL flips */
[dir="rtl"] .cc-time{margin-left:0;margin-right:auto;}
[dir="rtl"] .col-chk{margin-left:0;margin-right:auto;}
[dir="rtl"] .geo-dist-badge{margin-left:0;}
[dir="rtl"] .nsc-bottom,[dir="rtl"] .section-hdr,[dir="rtl"] .shift-item,[dir="rtl"] .store-row{flex-direction:row-reverse;}
[dir="rtl"] .detail-hdr,[dir="rtl"] .info-row,[dir="rtl"] .cc-status,[dir="rtl"] .geo-row{flex-direction:row-reverse;}
[dir="rtl"] .lang-chk{margin-left:0;margin-right:auto;}

/* TOAST */
.toast{position:absolute;bottom:88px;left:50%;transform:translateX(-50%) translateY(10px);background:#1a1a1c;color:#fff;padding:10px 18px;border-radius:20px;font-size:12px;font-weight:500;white-space:nowrap;opacity:0;transition:all .3s;pointer-events:none;z-index:999;}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0);}

/* ── LEAVE SCREEN ── */
.leave-balance-row{display:flex;gap:8px;padding:0 16px 12px;flex-shrink:0;}
.balance-box{flex:1;background:var(--card);border:1px solid var(--border);border-radius:var(--radius-sm);padding:11px 10px;text-align:center;}
.balance-num{font-size:22px;font-weight:600;letter-spacing:-.5px;}
.balance-lbl{font-size:10px;color:var(--muted);margin-top:3px;font-weight:500;text-transform:uppercase;letter-spacing:.04em;}
.leave-type-row{display:flex;gap:7px;padding:0 16px 12px;flex-shrink:0;overflow-x:auto;}
.leave-type-row::-webkit-scrollbar{display:none;}
.ltype-btn{padding:7px 14px;border-radius:20px;font-size:12px;font-weight:600;border:1.5px solid var(--border);background:var(--card);color:var(--muted);cursor:pointer;white-space:nowrap;transition:all .15s;font-family:inherit;}
.ltype-btn.sel{border-color:var(--accent);background:var(--accent-light);color:var(--accent);}
.leave-form-card{margin:0 16px 12px;background:var(--card);border-radius:var(--radius);border:1px solid var(--border);padding:14px 16px;flex-shrink:0;}
.lf-label{font-size:11px;color:var(--muted);font-weight:500;text-transform:uppercase;letter-spacing:.05em;margin-bottom:6px;}
.lf-date-row{display:flex;gap:8px;margin-bottom:12px;}
.lf-date-box{flex:1;border:1px solid var(--border);border-radius:var(--radius-sm);padding:10px 12px;background:var(--bg,#f5f4f1);cursor:pointer;transition:border-color .15s;}
.lf-date-box:focus-within{border-color:var(--accent);}
.lf-date-lbl{font-size:10px;color:var(--muted);font-weight:500;text-transform:uppercase;letter-spacing:.04em;margin-bottom:3px;}
.lf-date-val{font-size:13px;font-weight:500;}
.lf-date-input{width:100%;border:none;background:transparent;font-family:inherit;font-size:13px;font-weight:500;color:var(--text);outline:none;cursor:pointer;}
.lf-note{width:100%;border:1px solid var(--border);border-radius:var(--radius-sm);padding:10px 12px;background:var(--bg,#f5f4f1);font-family:inherit;font-size:13px;color:var(--text);resize:none;outline:none;transition:border-color .15s;min-height:64px;}
.lf-note:focus{border-color:var(--accent);}
.duration-badge{display:inline-block;font-size:12px;font-weight:600;padding:4px 12px;border-radius:20px;background:var(--accent-light);color:var(--accent);margin-bottom:12px;}
.submit-leave-btn{width:100%;padding:13px;border-radius:var(--radius-sm);background:var(--accent);color:#fff;font-size:14px;font-weight:600;border:none;cursor:pointer;font-family:inherit;transition:all .15s;margin-top:4px;}
.submit-leave-btn:active{transform:scale(.98);}
.submit-leave-btn:disabled{opacity:.4;cursor:not-allowed;}
.leave-history-item{background:var(--card);border-radius:var(--radius-sm);padding:12px 14px;margin:0 16px 8px;border:1px solid var(--border);flex-shrink:0;}
.lhi-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:5px;}
.lhi-type{font-size:13px;font-weight:600;}
.lhi-dates{font-size:12px;color:var(--muted);margin-bottom:4px;}
.lhi-note{font-size:12px;color:var(--muted);font-style:italic;}
.leave-pill{font-size:11px;font-weight:600;padding:3px 9px;border-radius:20px;}
.lp-pending{background:rgba(234,88,12,.1);color:var(--orange);}
.lp-approved{background:var(--green-light);color:var(--green);}
.lp-rejected{background:var(--red-light);color:var(--red);}
[dir="rtl"] .lf-date-row,[dir="rtl"] .leave-balance-row,[dir="rtl"] .lhi-top{flex-direction:row-reverse;}
</style>
</head>
<body>
<div class="phone">
  <div class="notch"><div class="notch-pill"></div></div>
  <div class="phone-body">

    <!-- ── TOP BAR (always visible, inside phone) ── -->
    <div class="phone-topbar">
      <div class="phone-topbar-left">shift<span>ly</span></div>
      <div style="display:flex;align-items:center;gap:8px;">
        <div class="status-icons">▲ WiFi ■</div>
        <!-- LANGUAGE PILL -->
        <div class="lang-pill" onclick="toggleLangMenu(event)" id="lang-pill">
          <span id="cur-flag" class="lang-flag-sm">🇫🇷</span>
          <span id="cur-name" style="font-size:12px;">FR</span>
          <span style="font-size:9px;opacity:.5;">▼</span>
          <!-- DROPDOWN -->
          <div class="lang-dropdown" id="lang-dd" onclick="event.stopPropagation()">
            <div class="lang-opt active" onclick="setLang('fr')" id="opt-fr"><span>🇫🇷</span> Français <span class="lang-chk" id="chk-fr">✓</span></div>
            <div class="lang-opt" onclick="setLang('en')" id="opt-en"><span>🇬🇧</span> English <span class="lang-chk" id="chk-en" style="display:none">✓</span></div>
            <div class="lang-opt" onclick="setLang('ar')" id="opt-ar"><span>🇲🇦</span> العربية <span class="lang-chk" id="chk-ar" style="display:none">✓</span></div>
            <div class="lang-opt" onclick="setLang('es')" id="opt-es"><span>🇪🇸</span> Español <span class="lang-chk" id="chk-es" style="display:none">✓</span></div>
            <div class="lang-opt" onclick="setLang('pt')" id="opt-pt"><span>🇧🇷</span> Português <span class="lang-chk" id="chk-pt" style="display:none">✓</span></div>
          </div>
        </div>
      </div>
