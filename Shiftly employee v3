let lang='fr', clockedIn=false, geoState='checking', simDist=null, selected=null;

/* ── HELPERS ── */
function haversine(a,b,c,d){
  const R=6371000,dL=(c-a)*Math.PI/180,dO=(d-b)*Math.PI/180;
  const x=Math.sin(dL/2)**2+Math.cos(a*Math.PI/180)*Math.cos(c*Math.PI/180)*Math.sin(dO/2)**2;
  return R*2*Math.atan2(Math.sqrt(x),Math.sqrt(1-x));
}
function showToast(msg){
  const t=document.getElementById('toast');
  t.textContent=msg;t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'),2800);
}
function goTo(s){
  document.querySelectorAll('.screen').forEach(x=>x.classList.remove('active'));
  document.getElementById('screen-'+s).classList.add('active');
  document.getElementById('screen-'+s).scrollTop=0;
}

/* ── GEO UI ── */
function applyGeoUI(state,dist){
  const t=T[lang];
  const row=document.getElementById('geo-row');
  const icon=document.getElementById('geo-icon');
  const text=document.getElementById('geo-text');
  const distBadge=document.getElementById('geo-dist');
  const btn=document.getElementById('clock-btn');
  const btnLbl=document.getElementById('clock-btn-label');
  const mapWrap=document.getElementById('map-wrap');
  const mapLbl=document.getElementById('map-label-bar');
  row.className='geo-row '+state;
  icon.className='geo-icon'+(state==='checking'?' pulse':'');
  if(state==='checking'){icon.textContent='📡';text.textContent=t.geoChecking;distBadge.style.display='none';btn.disabled=true;btnLbl.textContent=t.clockBtnWaiting;mapWrap.classList.remove('show');}
  else if(state==='in-range'){icon.textContent='✓';text.textContent=t.geoInRange;distBadge.style.display='inline';distBadge.textContent=Math.round(dist)+'m '+t.distFrom;mapWrap.classList.add('show');mapLbl.textContent=t.mapLabel;if(!clockedIn){btn.disabled=false;btnLbl.textContent=t.clockBtnReady;}placeUserDot(true);}
  else if(state==='out-range'){icon.textContent='✕';text.textContent=t.geoOutRange;distBadge.style.display='inline';distBadge.textContent=Math.round(dist)+'m '+t.distFrom;btn.disabled=true;btnLbl.textContent=t.clockBtnFar;mapWrap.classList.add('show');mapLbl.textContent=t.mapLabel;placeUserDot(false);}
  else{icon.textContent='✕';text.textContent=t.geoDenied;distBadge.style.display='none';btn.disabled=true;btnLbl.textContent=t.clockBtnDenied;mapWrap.classList.remove('show');}
}

function placeUserDot(inRange){
  const dot=document.getElementById('user-dot');
  const cx=188,cy=50;
  if(inRange){const a=Math.random()*Math.PI*2,r=10+Math.random()*20;dot.setAttribute('cx',cx+r*Math.cos(a));dot.setAttribute('cy',cy+r*Math.sin(a));dot.setAttribute('fill','#16a34a');}
  else{const a=Math.random()*Math.PI*2,r=50+Math.random()*15;dot.setAttribute('cx',cx+r*Math.cos(a));dot.setAttribute('cy',cy+r*Math.sin(a));dot.setAttribute('fill','#dc2626');}
}

function startGeo(){
  applyGeoUI('checking',0);
  if(navigator.geolocation){
    navigator.geolocation.getCurrentPosition(pos=>{
      const d=haversine(pos.coords.latitude,pos.coords.longitude,STORE_LAT,STORE_LNG);
      simDist=d;geoState=d<=RADIUS_M?'in-range':'out-range';applyGeoUI(geoState,d);
    },()=>simulate(),{enableHighAccuracy:true,timeout:6000});
  } else simulate();
}

function simulate(){
  setTimeout(()=>{simDist=310;geoState='out-range';applyGeoUI('out-range',310);
    setTimeout(()=>{simDist=145;geoState='in-range';applyGeoUI('in-range',145);},2200);
  },1500);
}

/* ── CLOCK ── */
function toggleClock(){
  const t=T[lang];
  if(!clockedIn){
    clockedIn=true;
    const now=new Date(),h=now.getHours().toString().padStart(2,'0'),m=now.getMinutes().toString().padStart(2,'0');
    document.getElementById('clock-dot').style.background='var(--green)';
    document.getElementById('clock-status-text').textContent=t.clockedInSince;
    document.getElementById('clock-time').textContent=h+':'+m;
    document.getElementById('clock-btn').classList.add('clocked-in');
    document.getElementById('clock-btn').disabled=false;
    document.getElementById('clock-btn-label').textContent=t.clockOutBtn;
    showToast(t.toastIn);
  } else {
    clockedIn=false;
    document.getElementById('clock-dot').style.background='var(--muted)';
    document.getElementById('clock-status-text').textContent=t.notClockedIn;
    document.getElementById('clock-time').textContent='';
    document.getElementById('clock-btn').classList.remove('clocked-in');
    document.getElementById('clock-btn-label').textContent=geoState==='in-range'?t.clockBtnReady:t.clockBtnFar;
    document.getElementById('clock-btn').disabled=geoState!=='in-range';
    showToast(t.toastOut);
  }
}

/* ── WEEK LIST ── */
function buildWeek(id,t,max){
  const c=document.getElementById(id);if(!c)return;
  const days=max?t.days.slice(0,max):t.days;
  const pm={done:'p-done',today:'p-today',conf:'p-ok',off:'p-off',pend:'p-pending'};
  const pt={done:t.done,today:t.today,conf:t.conf,off:t.off,pend:t.pend};
  c.innerHTML=days.map((d,i)=>`
    <div class="shift-item${d.t?' today':''}" onclick="${d.t?"goTo('detail')":""}">
      <div class="day-col"><div class="day-name">${d.n}</div><div class="day-num${d.t?' tnow':''}">${d.d}</div></div>
      <div class="vdivider"></div>
      <div class="shift-info"><div class="shift-time">${t.shifts[i]}</div><div class="shift-role-lbl">${t.roleLabel}</div></div>
      <span class="pill ${pm[t.sts[i]]}">${pt[t.sts[i]]}</span>
    </div>`).join('');
}

/* ── SWAP ── */
function selectCol(id){
  if(selected===id){selected=null;document.getElementById('col-'+id).classList.remove('selected');document.getElementById('chk-col-'+id).classList.remove('on');document.getElementById('chk-col-'+id).textContent='';document.getElementById('send-btn').disabled=true;return;}
  [1,2].forEach(i=>{document.getElementById('col-'+i)?.classList.remove('selected');document.getElementById('chk-col-'+i).classList.remove('on');document.getElementById('chk-col-'+i).textContent='';});
  selected=id;document.getElementById('col-'+id).classList.add('selected');document.getElementById('chk-col-'+id).classList.add('on');document.getElementById('chk-col-'+id).textContent='✓';document.getElementById('send-btn').disabled=false;
}
function sendSwap(){showToast(T[lang].toastSwap);selected=null;[1,2].forEach(i=>{document.getElementById('col-'+i)?.classList.remove('selected');document.getElementById('chk-col-'+i).classList.remove('on');document.getElementById('chk-col-'+i).textContent='';});document.getElementById('send-btn').disabled=true;setTimeout(()=>goTo('home'),1500);}
function confirmShift(){showToast(T[lang].toastConfirm);setTimeout(()=>goTo('home'),1200);}
function declineShift(){showToast(T[lang].toastDecline);setTimeout(()=>goTo('home'),1200);}

/* ── LANG ── */
function toggleLangMenu(e){e.stopPropagation();document.getElementById('lang-dd').classList.toggle('open');}
document.addEventListener('click',()=>document.getElementById('lang-dd').classList.remove('open'));

function setLang(l){
  lang=l;const t=T[l];
  document.documentElement.setAttribute('lang',l);
  document.documentElement.setAttribute('dir',t.dir);
  document.getElementById('cur-flag').textContent=t.flag;
  document.getElementById('cur-name').textContent=t.code;
  document.querySelectorAll('.lang-opt').forEach(o=>o.classList.remove('active'));
  document.querySelectorAll('.lang-chk').forEach(c=>c.style.display='none');
  document.getElementById('opt-'+l).classList.add('active');
  document.getElementById('chk-'+l).style.display='inline';
  document.getElementById('lang-dd').classList.remove('open');
  document.querySelectorAll('[data-i18n]').forEach(el=>{const k=el.getAttribute('data-i18n');if(t[k]!==undefined)el.textContent=t[k];});
  // store info (always same, language-independent display)
  document.getElementById('store-name-display').textContent=STORE_DATA.name;
  document.getElementById('store-addr-display').textContent=STORE_DATA.addr;
  document.getElementById('store-radius-display').textContent=STORE_DATA.radius;
  document.getElementById('profile-store-name').textContent=STORE_DATA.name;
  document.getElementById('profile-store-addr').textContent=STORE_DATA.addr;
  // re-apply geo text with new lang
  applyGeoUI(geoState, simDist||145);
  // clock state
  if(clockedIn){document.getElementById('clock-status-text').textContent=t.clockedInSince;document.getElementById('clock-btn-label').textContent=t.clockOutBtn;}
  // swap availability
  document.querySelectorAll('.col-avail:not(.busy)').forEach(e=>e.textContent=t.available);
  document.querySelectorAll('.col-avail.busy').forEach(e=>e.textContent=t.busy);
  // update leave note placeholder
  const noteEl = document.getElementById('leave-note');
  if (noteEl && t.lfNotePlaceholder) noteEl.placeholder = t.lfNotePlaceholder;
  // re-sync leave type buttons text
  const ltRow = document.getElementById('leave-type-row');
  if (ltRow) {
    const types = ['paid','rtt','sick','unpaid','other'];
    const keys = ['typePaid','typeRTT','typeSick','typeUnpaid','typeOther'];
    ltRow.querySelectorAll('.ltype-btn').forEach((btn,i) => { btn.textContent = t[keys[i]]; if(types[i]===selectedLeaveType) btn.classList.add('sel'); else btn.classList.remove('sel'); });
  }
  buildWeek('home-week',t,5);
  buildWeek('full-week',t,null);
  renderLeaveHistory();
}

/* ── LEAVE ── */
let selectedLeaveType = 'paid';

function selectLeaveType(btn, type) {
  selectedLeaveType = type;
  document.querySelectorAll('.ltype-btn').forEach(b => b.classList.remove('sel'));
  btn.classList.add('sel');
}

function calcDuration() {
  const from = document.getElementById('leave-from').value;
  const to = document.getElementById('leave-to').value;
  const badge = document.getElementById('duration-badge');
  const submitBtn = document.getElementById('submit-leave-btn');
  const t = T[lang];
  if (from && to) {
    const d1 = new Date(from), d2 = new Date(to);
    if (d2 >= d1) {
      const diff = Math.round((d2 - d1) / 86400000) + 1;
      badge.style.display = 'inline-block';
      badge.textContent = diff + ' ' + (diff === 1 ? t.durationDay : t.durationDays);
      submitBtn.disabled = false;
      // Auto-set to min == from if to < from
      if (d2 < d1) document.getElementById('leave-to').value = from;
    } else {
      badge.style.display = 'none';
      submitBtn.disabled = true;
    }
  } else {
    badge.style.display = 'none';
    submitBtn.disabled = true;
  }
}

function submitLeave() {
  const t = T[lang];
  const from = document.getElementById('leave-from').value;
  const to = document.getElementById('leave-to').value;
  const note = document.getElementById('leave-note').value;
  if (!from || !to) return;
  const diff = Math.round((new Date(to) - new Date(from)) / 86400000) + 1;
  const typeMap = {paid: t.typePaid, rtt: t.typeRTT, sick: t.typeSick, unpaid: t.typeUnpaid, other: t.typeOther};
  const fmt = d => { const p = d.split('-'); return p[2]+'/'+p[1]; };
  // Add to history
  const newItem = {type: typeMap[selectedLeaveType], from: fmt(from), to: fmt(to), days: diff, note: note, status: 'pending'};
  T[lang].leaveItems.unshift(newItem);
  // Reset form
  document.getElementById('leave-from').value = '';
  document.getElementById('leave-to').value = '';
  document.getElementById('leave-note').value = '';
  document.getElementById('duration-badge').style.display = 'none';
  document.getElementById('submit-leave-btn').disabled = true;
  renderLeaveHistory();
  showToast(t.toastLeave);
}

function renderLeaveHistory() {
  const t = T[lang];
  const list = document.getElementById('leave-history-list');
  if (!list) return;
  const statusMap = {pending: t.statusPending, approved: t.statusApproved, rejected: t.statusRejected};
  const statusClass = {pending: 'lp-pending', approved: 'lp-approved', rejected: 'lp-rejected'};
  list.innerHTML = (t.leaveItems || []).map(item => `
    <div class="leave-history-item">
      <div class="lhi-top">
        <div class="lhi-type">${item.type}</div>
        <span class="leave-pill ${statusClass[item.status]}">${statusMap[item.status]}</span>
      </div>
      <div class="lhi-dates">${item.from} → ${item.to} · ${item.days} ${item.days === 1 ? t.durationDay : t.durationDays}</div>
      ${item.note ? `<div class="lhi-note">${item.note}</div>` : ''}
    </div>`).join('');
}

setLang('fr');
startGeo();
</script>
